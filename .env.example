# Copy to .env and fill in. NEVER commit .env.
# All vars are prefixed SAM_ and map to nested settings via "__".

# --- App ---
SAM_ENV=local
SAM_LOG_LEVEL=INFO
SAM_LOG_JSON=true

# --- Database (Postgres + pgvector) ---
# For local dev against the docker-compose DB, use port 5433 (the compose
# stack publishes container 5432 -> host 5433 to avoid host-native Postgres).
SAM_DB__HOST=localhost
SAM_DB__PORT=5433
SAM_DB__USER=sam
SAM_DB__PASSWORD=sam
SAM_DB__NAME=sam

# --- Reddit (https://www.reddit.com/prefs/apps) ---
SAM_REDDIT__CLIENT_ID=
SAM_REDDIT__CLIENT_SECRET=
SAM_REDDIT__USER_AGENT=social-arbitrage-model/0.1 by u/yourname

# --- Kaggle (https://www.kaggle.com/settings -> API token) ---
# Bridged to KAGGLE_USERNAME/KAGGLE_KEY for the kaggle client; alternatively
# place kaggle.json in ~/.kaggle/ (that file wins if both are present).
SAM_KAGGLE__USERNAME=
SAM_KAGGLE__KEY=

# --- LLM (hybrid: Claude for report narration) ---
SAM_LLM__ANTHROPIC_API_KEY=
SAM_LLM__REPORT_MODEL=claude-opus-4-8

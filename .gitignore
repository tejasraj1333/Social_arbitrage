# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.eggs/
build/
dist/

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
coverage.xml

# Env & secrets
.env
.env.*
!.env.example

# Models & data artifacts (tracked via registry/DVC, not git)
models/
data/*
# ...except small Phase-1 recon proof samples + scorecard (committed as evidence).
# Must use `data/*` (not `data/`) so this re-include is honored — git cannot
# un-ignore a child of a fully-ignored directory.
!data/sample/
*.ckpt
*.pt
*.bin

# Notebooks scratch
.ipynb_checkpoints/

# OS / IDE
.DS_Store
.idea/
.vscode/
